# .env.hostinger.example — Environment variables for Hostinger validation deploy
#
# Copy this file to .env.hostinger on the server and fill in real values.
# NEVER commit .env.hostinger to the repo.
#
#   cp .env.hostinger.example .env.hostinger
#   nano .env.hostinger
#
# Usage:
#   docker compose -f docker-compose.hostinger.yml --env-file .env.hostinger up -d

# ---------------------------------------------------------------------------
# PostgreSQL — data layer password
# Used by: docker-compose.hostinger.yml, FastAPI backend services (Phase 6-B)
# ---------------------------------------------------------------------------
MEDPRO_PG_PASSWORD=changeme_strong_password_here

# ---------------------------------------------------------------------------
# Redis — cache + rate-limit store password
# Used by: docker-compose.hostinger.yml, FastAPI backend services (Phase 6-B)
# ---------------------------------------------------------------------------
MEDPRO_REDIS_PASSWORD=changeme_strong_password_here

# ---------------------------------------------------------------------------
# Application DATABASE URLs (set these for Phase 6-B service wiring)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+psycopg2://medpro_admin:MEDPRO_PG_PASSWORD@127.0.0.1:5432/medpro
# AUDIT_DATABASE_URL=postgresql+psycopg2://medpro_admin:MEDPRO_PG_PASSWORD@127.0.0.1:5432/medpro_audit
# REDIS_URL=redis://:MEDPRO_REDIS_PASSWORD@127.0.0.1:6379/0
