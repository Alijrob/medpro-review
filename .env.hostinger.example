# .env.hostinger.example -- Environment variables for Hostinger validation deploy
#
# Copy this file to .env.hostinger on the server and fill in real values.
# NEVER commit .env.hostinger to the repo.
#
#   cp .env.hostinger.example .env.hostinger
#   nano .env.hostinger
#
# Usage (Phase 6-B):
#   bash scripts/pm2-start.sh start
#
# The pm2-start.sh script sources this file, builds the frontend, then
# calls pm2 start ecosystem.config.js.  All vars here are exported into
# the environment before PM2 spawns its child processes.

# ---------------------------------------------------------------------------
# PostgreSQL passwords (Phase 6-A)
# Used to build the DATABASE_URL / AUDIT_DATABASE_URL below.
# ---------------------------------------------------------------------------
MEDPRO_PG_PASSWORD=changeme_strong_password_here

# ---------------------------------------------------------------------------
# Redis password (Phase 6-A)
# Used to build REDIS_URL below.
# ---------------------------------------------------------------------------
MEDPRO_REDIS_PASSWORD=changeme_strong_password_here

# ---------------------------------------------------------------------------
# Shared database + cache connection URLs (Phase 6-B)
# Replace <PG_PASSWORD> and <REDIS_PASSWORD> with the values above.
# These are consumed by: auth-service, api-gateway, audit-service,
# source-monitor, report-service, payment-service.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://medpro_admin:<PG_PASSWORD>@127.0.0.1:5432/medpro
AUDIT_DATABASE_URL=postgresql+psycopg2://medpro_admin:<PG_PASSWORD>@127.0.0.1:5432/medpro_audit
REDIS_URL=redis://:<REDIS_PASSWORD>@127.0.0.1:6379/0

# ---------------------------------------------------------------------------
# Auth0 (Phase 6-D -- fill in when tenant is provisioned)
# Used by: auth-service, api-gateway, frontend
# ---------------------------------------------------------------------------
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=

# Next.js server-side Auth0 SDK settings
AUTH0_SECRET=                    # openssl rand -hex 32
AUTH0_BASE_URL=https://researchyourdoctor.com
AUTH0_ISSUER_BASE_URL=           # https://<AUTH0_DOMAIN>.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Stripe (Phase 6-D -- fill in when Stripe account is live)
# Used by: payment-service
# ---------------------------------------------------------------------------
PAYMENT_STRIPE_SECRET_KEY=       # sk_live_...  (or sk_test_... for testing)
PAYMENT_STRIPE_WEBHOOK_SECRET=   # whsec_...
PAYMENT_STRIPE_PRICE_ID=         # price_...

# ---------------------------------------------------------------------------
# OpenSearch (not installed on Hostinger for Phase 6-B)
# Search service boots but returns 503 on search endpoints until this is set.
# ---------------------------------------------------------------------------
SEARCH_OPENSEARCH_URL=http://127.0.0.1:9200
SEARCH_OPENSEARCH_PASSWORD=
SEARCH_INDEX_NAME=providers-prod

# ---------------------------------------------------------------------------
# Temporal (not installed on Hostinger for Phase 6-B)
# report-service boots but workflows fail to dispatch until Temporal is live.
# ---------------------------------------------------------------------------
REPORT_TEMPORAL_ADDRESS=localhost:7233

# ---------------------------------------------------------------------------
# Sentry SaaS (optional -- blank disables it cleanly)
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Poetry binary path (default: /root/.local/bin/poetry)
# Override only if poetry was installed outside the default location.
# ---------------------------------------------------------------------------
# POETRY_BIN=/root/.local/bin/poetry
