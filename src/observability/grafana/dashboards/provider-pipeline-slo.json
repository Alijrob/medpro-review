{
  "uid": "medpro-pipeline-slo",
  "title": "medpro-review — Provider Pipeline SLO",
  "tags": ["medpro-review", "slo", "pipeline"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(service:http_requests:rate5m, service_name)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Report Workflow Success Ratio (15m)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "pipeline:report_workflow_success:ratio15m", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Report Generation p95 Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "pipeline:report_duration_p95:5m", "refId": "A", "legendFormat": "p95" }
      ]
    },
    {
      "id": 3,
      "title": "Per-Service Error Ratio (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "service:http_errors:ratio5m{service_name=~\"$service\"}",
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Per-Service p99 Latency (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "service:http_latency_p99:5m{service_name=~\"$service\"}",
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Request Rate (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "service:http_requests:rate5m{service_name=~\"$service\"}",
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ]
    }
  ]
}
