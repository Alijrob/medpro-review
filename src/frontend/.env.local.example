# Auth0 (required)
# Create a Regular Web App in your Auth0 tenant.
# Allowed Callback URLs:  http://localhost:3100/api/auth/callback
# Allowed Logout URLs:    http://localhost:3100
AUTH0_SECRET=use-openssl-rand-hex-32-to-generate
AUTH0_BASE_URL=http://localhost:3100
AUTH0_ISSUER_BASE_URL=https://YOUR_AUTH0_DOMAIN.auth0.com
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET

# App base URL (used by the payments proxy to build Stripe return URLs)
# In production this is https://researchyourdoctor.com
# In local dev: http://localhost:3100  (must match AUTH0_BASE_URL)
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Backend service URLs (default to local dev ports)
SEARCH_SERVICE_URL=http://localhost:8003
REPORT_SERVICE_URL=http://localhost:8004
PAYMENT_SERVICE_URL=http://localhost:8005
